<Window
    x:Class="Pyro.Settings.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Pyro Settings"
    Width="940"
    Height="860">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Padding="24">
                <TextBlock Text="Pyro Settings" FontSize="30" FontWeight="SemiBold" />
                <TextBlock x:Name="ConfigPathText" Opacity="0.75" TextWrapping="Wrap" />
                <TextBlock x:Name="StatusText" TextWrapping="Wrap" />

                <Border Padding="16" CornerRadius="8" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Capture Defaults" FontSize="20" FontWeight="SemiBold" />

                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Capture Hotkey" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="CaptureHotkeyTextBox" PlaceholderText="PrintScreen or Ctrl+Shift+S" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Default Target" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DefaultTargetComboBox">
                                <ComboBoxItem Content="Region" Tag="region" />
                                <ComboBoxItem Content="Primary" Tag="primary" />
                                <ComboBoxItem Content="All Displays" Tag="all-displays" />
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Default Delay (ms)" VerticalAlignment="Center" />
                            <NumberBox Grid.Row="2" Grid.Column="1" x:Name="DefaultDelayNumberBox" SmallChange="100" LargeChange="500" Minimum="0" SpinButtonPlacementMode="Inline" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Save Directory" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="SaveDirTextBox" PlaceholderText="C:\\Users\\...\\Pictures\\Pyro" />

                            <CheckBox Grid.Row="4" Grid.Column="1" x:Name="CopyToClipboardCheckBox" Content="Copy to clipboard by default" />
                        </Grid>

                        <CheckBox x:Name="OpenEditorCheckBox" Content="Open region editor by default" />
                    </StackPanel>
                </Border>

                <Border Padding="16" CornerRadius="8" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Editor" FontSize="20" FontWeight="SemiBold" />

                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Text Commit Feedback Color" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TextCommitFeedbackColorTextBox" PlaceholderText="#48B4FF" />
                        </Grid>

                        <TextBlock Text="Editor Shortcuts" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />

                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Select" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="SelectShortcutTextBox" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Rectangle" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="3" x:Name="RectangleShortcutTextBox" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ellipse" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="EllipseShortcutTextBox" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Line" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="3" x:Name="LineShortcutTextBox" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Arrow" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ArrowShortcutTextBox" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Marker" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="3" x:Name="MarkerShortcutTextBox" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Text" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="TextShortcutTextBox" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Pixelate" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="3" x:Name="PixelateShortcutTextBox" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Blur" VerticalAlignment="Center" />
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="BlurShortcutTextBox" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="Copy" VerticalAlignment="Center" />
                            <TextBox Grid.Row="4" Grid.Column="3" x:Name="CopyShortcutTextBox" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Save" VerticalAlignment="Center" />
                            <TextBox Grid.Row="5" Grid.Column="1" x:Name="SaveShortcutTextBox" />
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="Copy+Save" VerticalAlignment="Center" />
                            <TextBox Grid.Row="5" Grid.Column="3" x:Name="CopyAndSaveShortcutTextBox" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Undo" VerticalAlignment="Center" />
                            <TextBox Grid.Row="6" Grid.Column="1" x:Name="UndoShortcutTextBox" />
                            <TextBlock Grid.Row="6" Grid.Column="2" Text="Redo" VerticalAlignment="Center" />
                            <TextBox Grid.Row="6" Grid.Column="3" x:Name="RedoShortcutTextBox" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Delete Selected" VerticalAlignment="Center" />
                            <TextBox Grid.Row="7" Grid.Column="1" x:Name="DeleteSelectedShortcutTextBox" />
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Reload" Click="ReloadButton_Click" />
                    <Button Content="Save" Click="SaveButton_Click" />
                    <Button Content="Close" Click="CloseButton_Click" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
